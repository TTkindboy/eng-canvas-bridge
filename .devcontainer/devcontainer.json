{
	"name": "English-Canvas-DevContainer",
"image": "mcr.microsoft.com/devcontainers/base:ubuntu",
	"features": {
		"ghcr.io/devcontainers/features/node:1": {
			"nodeGypDependencies": true,
			"version": "lts",
			"pnpmVersion": "latest",
			"nvmVersion": "latest"
		},
		"ghcr.io/va-h/devcontainers-features/uv:1": {
			"shellautocompletion": true,
			"version": "latest"
		},
		"ghcr.io/devcontainers/features/git-lfs:1": {
			"autoPull": true,
			"version": "latest"
		}
	}, 
	"onCreateCommand": "uv python install 3.13 && uv tool install rust-just && curl -fsSL https://github.com/terror/just-lsp/releases/download/0.4.0/just-lsp-0.4.0-x86_64-unknown-linux-gnu.tar.gz | tar xz && sudo install just-lsp /usr/local/bin/",
	"customizations": {
		"vscode": {
			"extensions": [
				"tamasfe.even-better-toml",
				"astral-sh.ty",
				"charliermarsh.ruff",
				"fastapilabs.fastapi-vscode",
				"nefrob.vscode-just-syntax", // small chance this is incorrect/deprecated extension
				"-ms-python.vscode-python-envs"
			],
			"settings": {
				"editor.inlayHints.enabled": "offUnlessPressed",
				"files.autoSave": "off",
				"ty.diagnosticMode": "workspace",
				"editor.codeLens": false,
				"vscode-just.lspPath": "/usr/local/bin/just-lsp",
				"fastapi.cloud.enabled": false,
				"python.useEnvironmentsExtension": false
			}
		}
	}

	// Use 'forwardPorts' to make a list of ports inside the container available locally.
	// "forwardPorts": [],

	// Uncomment to connect as root instead. More info: https://aka.ms/dev-containers-non-root.
	// "remoteUser": "root"
}
